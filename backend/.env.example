# ─── Copy this file to .env and fill in the values ───────────────────────────
# Do NOT commit .env to git. Add it to .gitignore.

# Django Secret Key — generate a strong random string:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-here

# Set to True ONLY for local development
DEBUG=False

# Comma-separated list of allowed hostnames (no spaces, no trailing slash)
# Example:  eduimperium-backend.onrender.com,localhost
ALLOWED_HOSTS=eduimperium-backend.onrender.com,localhost

# Render PostgreSQL connection string — Render sets this automatically when you
# attach a database. You only need this locally.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Comma-separated list of trusted frontend origins (no trailing slash)
CORS_ALLOWED_ORIGINS=https://eduimperium-frontend.onrender.com

# Comma-separated CSRF trusted origins (must include scheme)
CSRF_TRUSTED_ORIGINS=https://eduimperium-backend.onrender.com,https://eduimperium-frontend.onrender.com
